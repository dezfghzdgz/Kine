# Supabase - najdeš v Supabase dashboardu -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Skutečná veřejná adresa appky (až bude appka nasazená) - appka to
# potřebuje pro sitemapu a náhledy odkazů. Do té doby klidně nech
# na http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://tvoje-domena.cz

# Cloudflare Stream - najdeš v Cloudflare dashboardu -> Stream
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-api-token

# GIFy v komentářích (nepovinné, appka bez toho zkusí sdílený klíč, který
# ale Giphy může kdykoliv zablokovat) - zdarma na developers.giphy.com
NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key
